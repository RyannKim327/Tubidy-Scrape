{
	"compilerOptions": {
		"target": "ES2020",
		"moduleResolution": "nodenext",
		"module": "NodeNext",
		"declaration": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true
	},
	"exclude": [
		"**/*/test.ts"
	]
}
